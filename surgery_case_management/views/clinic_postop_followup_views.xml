<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard form -->
    <record id="view_clinic_postop_followup_form" model="ir.ui.view">
        <field name="name">clinic.postop.followup.form</field>
        <field name="model">clinic.postop.followup</field>
        <field name="arch" type="xml">
            <form string="Post-op Follow-up">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_consults" type="object"
                                class="oe_stat_button" icon="fa-stethoscope">
                            <field name="consult_count" widget="statinfo" string="Consults"/>
                        </button>
                        <button name="action_view_pending_consults" type="object"
                                class="oe_stat_button" icon="fa-clock-o"
                                invisible="consult_pending_count == 0">
                            <field name="consult_pending_count" widget="statinfo" string="Pending"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="patient_id"/>
                        <h1><field name="patient_id" options="{'no_create': True}"/></h1>
                    </div>

                    <group>
                        <group string="Surgeries">
                            <field name="surgery_case_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                        <group string="Progress">
                            <field name="consult_count"/>
                            <field name="consult_done_count"/>
                            <field name="consult_pending_count"
                                   decoration-danger="consult_pending_count > 0"
                                   decoration-success="consult_pending_count == 0"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Post-op Consults" name="postop_consults">
                            <field name="postop_consult_ids" readonly="0">
                                <list editable="bottom"
                                      decoration-success="consult_done"
                                      decoration-muted="not is_fixed">
                                    <field name="surgery_case_id"/>
                                    <field name="source_procedure_id"/>
                                    <field name="label"/>
                                    <field name="planned_date"/>
                                    <field name="is_fixed" widget="boolean_toggle"/>
                                    <field name="mediris_booked" widget="boolean_toggle"/>
                                    <field name="consult_done" widget="boolean_toggle"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <!-- Remove if clinic.postop.followup doesn't inherit mail.thread -->
                <chatter/>
            </form>
        </field>
    </record>
