<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_add_sign_signature" model="ir.ui.view">
        <field name="name">res.users.form.add.sign.signature</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='other_preferences']" position="inside">
                <field name="sign_signature" widget="signature"
                       options="{'full_name': 'name'}"
                       string="Doctor Signature"/>
            </xpath>
        </field>
    </record>
</odoo>