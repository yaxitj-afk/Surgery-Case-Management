<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         ADMISSION POINT FORM
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_admission_point_form" model="ir.ui.view">
        <field name="name">admission.point.form</field>
        <field name="model">admission.point</field>
        <field name="arch" type="xml">
            <form string="Admission Point">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Reception Desk A"/>
                        </h1>
                    </div>
                    <group>
                        <field name="admission_type"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         ADMISSION POINT LIST
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_admission_point_list" model="ir.ui.view">
        <field name="name">admission.point.list</field>
        <field name="model">admission.point</field>
        <field name="arch" type="xml">
            <list string="Admission Points" editable="bottom">
                <field name="name"/>
                <field name="admission_type"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         ADMISSION POINT SEARCH
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_admission_point_search" model="ir.ui.view">
        <field name="name">admission.point.search</field>
        <field name="model">admission.point</field>
        <field name="arch" type="xml">
            <search string="Admission Points">
                <field name="name"/>
                <field name="admission_type"/>
                <filter string="Day Care" name="filter_daycare"
                        domain="[('admission_type', '=', 'daycare')]"/>
                <filter string="Overnight Stay" name="filter_overnight"
                        domain="[('admission_type', '=', 'overnight')]"/>
                <filter string="Private Practice" name="filter_private"
                        domain="[('admission_type', '=', 'private')]"/>
                <filter string="Admission Type" name="group_by_type"
                            context="{'group_by': 'admission_type'}"/>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         ACTION + MENU
    ═══════════════════════════════════════════════════════════ -->
    <record id="action_admission_point" model="ir.actions.act_window">
        <field name="name">Admission Points</field>
        <field name="res_model">admission.point</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first admission point
            </p>
        </field>
    </record>

    <menuitem id="menu_admission_point_config"
              name="Admission Points"
              parent="menu_surgery_configuration"
              action="action_admission_point"
              sequence="30"/>

</odoo>