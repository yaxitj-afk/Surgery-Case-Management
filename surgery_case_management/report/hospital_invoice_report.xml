<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_hospital_invoice_v2">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang"/>
                <t t-set="company" t-value="o.company_id.sudo()"/>
                <t t-call="surgery_case_management.report_hospital_invoice_document_v2" t-lang="lang"/>
            </t>
        </t>
    </template>

    <template id="report_hospital_invoice_document_v2">
