<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="report_admission_document" model="ir.actions.report">
        <field name="name">Admission Document</field>
        <field name="model">clinic.admission.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">surgery_case_management.admission_document_template</field>
        <field name="report_file">surgery_case_management.admission_document_template</field>
        <field name="print_report_name">'Opnamedocument - ' + object.patient_id.name</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>